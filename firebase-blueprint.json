{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile containing roles and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["Admin", "Organizer", "Attendee"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Seminar": {
      "title": "Seminar",
      "description": "A seminar event containing details and logistics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "capacity": { "type": "integer" },
        "status": { "type": "string", "enum": ["Draft", "Published", "Closed"] },
        "organizerId": { "type": "string" },
        "category": { "type": "string" },
        "registeredCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "startDate", "endDate", "venue", "capacity", "status", "organizerId", "category"]
    },
    "Session": {
      "title": "Session",
      "description": "A specific sub-session inside a seminar.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "seminarId": { "type": "string" },
        "title": { "type": "string" },
        "speakerName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["seminarId", "title", "speakerName", "startTime", "endTime"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A user's registration for a seminar.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "seminarId": { "type": "string" },
        "seminarTitle": { "type": "string" },
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["registered", "waitlisted", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "seminarId", "seminarTitle", "code", "status", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "An attendance log for a specific session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registrationId": { "type": "string" },
        "sessionId": { "type": "string" },
        "seminarId": { "type": "string" },
        "checkedInAt": { "type": "string", "format": "date-time" },
        "checkedInBy": { "type": "string" }
      },
      "required": ["registrationId", "sessionId", "seminarId", "checkedInAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/seminars/{seminarId}": {
      "schema": "Seminar",
      "description": "Seminars listed in the system"
    },
    "/seminars/{seminarId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Sessions for a specific seminar"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Registrations for seminars"
    },
    "/seminars/{seminarId}/sessions/{sessionId}/attendances/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance logs for a specific session"
    }
  }
}
